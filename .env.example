# ======================================================
# Plantilla de variables de entorno
# Copia este archivo como .env y llena tus valores reales
# NUNCA subas .env a Git
# ======================================================

# API Key de Groq
# Obtén la tuya en: https://console.groq.com/
GROQ_API_KEY=tu_api_key_aqui

# Umbral de confianza para detecciones YOLO (0.0 - 1.0)
# Valor recomendado: 0.4 (40%)
CONF_THRESHOLD=0.4

# Modelo Groq a usar
GROQ_MODEL=llama-3.3-70b-versatile
