# =============================================
# .gitignore — Sistema Detección de Daños YOLO
# =============================================

# Variables de entorno (¡nunca subir API keys!)
.env

# Modelo entrenado (se permite subir best.pt para facilidad de despliegue)
# models/best.pt
# models/*.pt
models/*.onnx

# Datasets sin procesar (demasiado grandes para Git)
data/raw/
data/dataset_final/
*.zip
data/*.zip

# Imágenes temporales de la app
app/temp_*
*.jpg
*.jpeg
*.png
!app/assets/*.png

# Resultados de entrenamiento YOLO
runs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
